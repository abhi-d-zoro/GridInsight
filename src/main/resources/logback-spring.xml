<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── Console: human-readable for local dev (default / dev profile) ── -->
    <springProfile name="default,dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>
                    %d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [correlationId=%X{correlationId}] [userId=%X{userId}] - %msg%n
                </pattern>
            </encoder>
        </appender>

        <logger name="com.gridinsight.backend" level="DEBUG"/>
        <logger name="org.springframework.security" level="DEBUG"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ── JSON: structured for production / ELK / Loki (prod / staging profile) ── -->
    <springProfile name="prod,staging">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <!-- MDC keys (correlationId, userId) are included automatically -->
                <includeMdcKeyName>correlationId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
            </encoder>
        </appender>

        <logger name="com.gridinsight.backend" level="INFO"/>

        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
    </springProfile>

</configuration>

